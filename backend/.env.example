OPENAI_API_KEY=your-api-key-here
VLLM_BASE_URL=your-vllm-endpoint-here

# Public, externally-reachable URL of the demo (without trailing slash).
# Used to construct shareable links so they work for visitors who aren't on
# localhost. Set this to your cloudflared / ngrok hostname, e.g.
#   PUBLIC_BASE_URL=https://med-likely-member-cia.trycloudflare.com
# If unset, the backend falls back to X-Forwarded-Host headers (set by most
# tunnels), then the request's Origin header. Localhost is the last resort.
PUBLIC_BASE_URL=
